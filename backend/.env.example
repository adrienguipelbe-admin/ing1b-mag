# ─── CONFIGURATION ING1B MAG ───────────────────────────────────
# Copie ce fichier en .env et remplis les valeurs

PORT=3001

# Génère une clé secrète longue et aléatoire (garde-la secrète !)
JWT_SECRET=remplace_par_une_longue_chaine_aleatoire_ex_abc123xyz456def789

# Ton email Google → ce compte aura automatiquement le rôle admin
ADMIN_EMAIL=ton.email@gmail.com

# Google OAuth Client ID (voir guide SETUP.md étape 3)
GOOGLE_CLIENT_ID=COLLE_TON_CLIENT_ID_ICI.apps.googleusercontent.com

# URL du frontend (pour les CORS)
FRONTEND_URL=http://localhost:5500
